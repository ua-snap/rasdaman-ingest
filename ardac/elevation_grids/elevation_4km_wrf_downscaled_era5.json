{
  "config": {
    "service_url": "https://localhost/rasdaman/ows",
    "tmp_directory": "/tmp/",
    "crs_resolver": "http://localhost:8080/def/",
    "default_crs": "http://localhost:8080/def/crs/EPSG/0/3338",
    "default_null_values": [
      "nan"
    ],
    "mock": false,
    "automated": true
  },
  "hooks": [
    {
      "description": "Create WMS terrain-style elevation colormap",
      "when": "after_import",
      "cmd": ". /etc/default/rasdaman; curl --user $RASCURL \"https://datacubes.earthmaps.io/rasdaman/admin/layer/style/add?COVERAGEID=era5_4km_elevation&STYLEID=terrain_elevation_ak&ABSTRACT=4km_grid_elevation&WCPSQUERYFRAGMENT=%24c&COLORTABLETYPE=ColorMap&\" --data-urlencode \"COLORTABLEDEFINITION={\\\"type\\\":\\\"intervals\\\",\\\"colorTable\\\":{\\\"-9999\\\":[0,0,0,0],\\\"0.01\\\":[10,10,10,255],\\\"50\\\":[20,90,40,255],\\\"200\\\":[60,140,60,255],\\\"500\\\":[160,170,80,255],\\\"1000\\\":[200,180,120,255],\\\"1500\\\":[190,160,120,255],\\\"2000\\\":[170,130,90,255],\\\"2750\\\":[140,110,80,255],\\\"3500\\\":[120,90,70,255],\\\"4250\\\":[210,210,210,255],\\\"5000\\\":[255,255,255,255]}}\"",
      "abort_on_error": true
    }
  ],
  "input": {
    "coverage_id": "era5_4km_elevation",
    "paths": [
      "/opt/rasdaman-storage/coverage_data/wrf_downscaled_era5_elevation_grids/elevation_grid_4km.nc"
    ]
  },
  "recipe": {
    "name": "general_coverage",
    "options": {
      "wms_import": true,
      "tiling": "ALIGNED [0:127, 0:127] tile size 65536",
      "import_order": "ascending",
      "coverage": {
        "crs": "EPSG/0/3338",
        "metadata": {
          "type": "xml",
          "global": {
            "Title": "'Elevation, Meters Above Sea Level, 4km WRF-ERA5 Grid'"
          }
        },
        "slicer": {
          "type": "netcdf",
          "pixelIsPoint": true,
          "bands": [
            {
              "name": "elevation",
              "identifier": "elevation"
            }
          ],
          "axes": {
            "X": {
              "min": "${netcdf:variable:x:min}",
              "max": "${netcdf:variable:x:max}",
              "resolution": "${netcdf:variable:x:resolution}",
              "gridOrder": 2
            },
            "Y": {
              "min": "${netcdf:variable:y:min}",
              "max": "${netcdf:variable:y:max}",
              "resolution": "${netcdf:variable:y:resolution}",
              "gridOrder": 1
            }
          }
        }
      }
    }
  }
}
