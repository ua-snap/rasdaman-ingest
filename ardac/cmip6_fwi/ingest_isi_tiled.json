{
  "config": {
    "service_url": "https://localhost/rasdaman/ows",
    "tmp_directory": "/tmp/",
    "mock": false,
    "automated": true
  },
  "input": {
    "coverage_id": "cmip6_isi",
    "paths": [
      "cmip6_isi_combined.nc"
    ]
  },
  "recipe": {
    "name": "general_coverage",
    "options": {
      "tiling": "ALIGNED [0:4, 0:*, 0:1, 0:1] tile size 1643456",
      "wms_import": true,
      "import_order": "ascending",
      "coverage": {
        "crs": "OGC/0/Index1D?axis-label=\"model\"@OGC/0/Index1D?axis-label=\"time\"@EPSG/0/4326",
        "metadata": {
          "type": "xml",
          "global": "auto"
        },
        "slicer": {
          "type": "netcdf",
          "pixelIsPoint": true,
          "bands": [
            {
              "name": "isi",
              "identifier": "isi",
              "nilValue": "nan"
            }
          ],
          "axes": {
            "model": {
              "min": "${netcdf:variable:model:min}",
              "max": "${netcdf:variable:model:max}",
              "directPositions": "${netcdf:variable:model}",
              "irregular": true,
              "gridOrder": 0
            },
            "time": {
              "min": "${netcdf:variable:time:min}",
              "max": "${netcdf:variable:time:max}",
              "directPositions": "${netcdf:variable:time}",
              "irregular": true,
              "gridOrder": 1
            },
            "lat": {
              "min": "${netcdf:variable:lat:min}",
              "max": "${netcdf:variable:lat:max}",
              "resolution": "${netcdf:variable:lat:resolution}",
              "gridOrder": 2
            },
            "lon": {
              "min": "${netcdf:variable:lon:min}",
              "max": "${netcdf:variable:lon:max}",
              "resolution": "${netcdf:variable:lon:resolution}",
              "gridOrder": 3
            }
          }
        }
      }
    }
  }
}
